# Copy to .env and adjust for local dev. NEVER commit the real .env.
# Every key here is read into app/config.py's Settings object.

# App environment: development | production
ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Postgres connection string used by BOTH the app (asyncpg) and yoyo (migrations).
# Inside docker compose the host is the service name "db", not localhost.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://recurring:recurring@db:5432/recurring

# Placeholder — used starting in B1 (auth) to sign JWTs. Generate a real random
# value for anything beyond local dev, e.g.:  openssl rand -hex 32
JWT_SECRET=dev-only-change-me-0123456789abcdef-0123456789

# Auth token lifetimes and login rate limiting (defaults are sensible; override
# only with a reason).
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
AUTH_RATE_LIMIT_MAX_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# CORS allowed origins for browser clients (comma-separated). "*" allows any
# origin — safe here because we auth with a bearer token, not cookies. In
# production set this to your app's exact origin(s), e.g. https://app.example.com
CORS_ALLOW_ORIGINS=*

# AI assistant (/v1/ai/chat). The model API key lives ONLY here on the server and
# is never shipped to the app. `fake` needs no key (deterministic dev stub). To use
# a real model set LLM_PROVIDER=anthropic and provide a key + model.
LLM_PROVIDER=fake
LLM_API_KEY=
LLM_MODEL=claude-3-5-haiku-latest
# Per-user throttle on the shared paid key.
AI_RATE_LIMIT_MAX_REQUESTS=30
AI_RATE_LIMIT_WINDOW_SECONDS=60
